DATABASE_URL=postgresql+asyncpg://vulnlab:vulnlab123@db:5432/vulnlab
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
SECRET_KEY=change-me-in-production
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10
FRONTEND_URL=http://localhost:4200

# LLM provider: "anthropic" or "ollama" (local)
AI_PROVIDER=ollama
ANTHROPIC_MODEL=claude-sonnet-4-6
# host.docker.internal reaches the host machine from inside Docker (Mac/Windows)
# On Linux add extra_\hosts: host.docker.internal:host-gateway to docker-compose.yaml
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=llama3.2
